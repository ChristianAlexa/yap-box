{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "yap-box",
  "version": "0.1.4",
  "identifier": "com.yapbox.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:9002",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "category": "public.app-category.utilities",
    "copyright": "Copyright © 2026 Christian Alexa",
    "macOS": { "minimumSystemVersion": "11.0" },
    "icon": ["icons/icon.icns"],
    "externalBin": ["binaries/koko"],
    "resources": ["resources/espeak-ng-data/**/*"]
  },
  "app": {
    "windows": [
      {
        "title": "yap-box",
        "width": 500,
        "height": 400,
        "minWidth": 350,
        "minHeight": 300,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: asset: https://asset.localhost; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src ipc: http://ipc.localhost"
    }
  }
}
